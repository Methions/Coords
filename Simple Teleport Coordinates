local presets = {}
local epsilon = 0.1
local angleEpsilon = math.rad(1)

local function getEuler(c)
return c:ToEulerAnglesYXZ()
end

local function isSameCFrame(c1, c2)
local p1 = c1.Position
local p2 = c2.Position
local rx1, ry1, rz1 = getEuler(c1)
local rx2, ry2, rz2 = getEuler(c2)
return (p1 - p2).Magnitude < epsilon and
 math.abs(rx1 - rx2) < angleEpsilon and
 math.abs(ry1 - ry2) < angleEpsilon and
 math.abs(rz1 - rz2) < angleEpsilon
end

local function addPreset(cframe)
for _, p in ipairs(presets) do
if isSameCFrame(p.cframe, cframe) then
return false
end
end
table.insert(presets, {cframe = cframe})
return true
end

