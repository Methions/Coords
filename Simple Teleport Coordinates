local function parseCoords(s)
if not s then
return nil, "no input"
end
local cleaned = s:gsub("[%(%)]",""):gsub(",", " "):gsub(";", " ")
cleaned = cleaned:gsub("%s+", " "):gsub("^%s+", ""):gsub("%s+$", "")
local parts = {}
for token in string.gmatch(cleaned, "[^%s]+") do
table.insert(parts, token)
end
if #parts < 3 then
return nil, "need 3 numbers (x y z)"
end
local x = tonumber(parts[1])
local y = tonumber(parts[2])
local z = tonumber(parts[3])
if not (x and y and z) then
return nil, "invalid numbers"
end
return Vector3.new(x, y, z)
end

local function teleportTo(cf, force, tween)
local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
if not char then return false, "no character" end
local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChildWhichIsA("BasePart")
if not hrp then return false, "no root part" end
 
local oldCf = hrp.CFrame
local ok, err = pcall(function()
if tween then
local tweenInfo = TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local tw = TweenService:Create(hrp, tweenInfo, {CFrame = cf})
tw:Play()
tw.Completed:Wait()
else
hrp.CFrame = cf
end
 
if force then
local attempts = 0
local maxAttempts = 20
while attempts < maxAttempts do
hrp.CFrame = cf
task.wait(0.05)
local currentPos = hrp.Position
if (currentPos - cf.Position).Magnitude < 5 then
break
end
attempts = attempts + 1
end
if attempts >= maxAttempts then
return false, "failed after multiple attempts"
end
end
end)
 
if not ok then
return false, tostring(err or "unknown error")
end
 
task.wait(0.5)
local currentCf = hrp.CFrame
local distToTarget = (currentCf.Position - cf.Position).Magnitude
local distToOld = (currentCf.Position - oldCf.Position).Magnitude
 
if distToTarget > 5 and distToOld < 5 then
return false, "reverted"
end
return true
end

