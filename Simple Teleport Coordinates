local function createToggle(name, settingKey, parent, customCallback)
local toggleFrame = Instance.new("Frame")
toggleFrame.Size = UDim2.new(1, -8, 0, 28)
toggleFrame.BackgroundTransparency = 1
toggleFrame.Parent = parent
 
local toggle = Instance.new("TextButton")
toggle.Size = UDim2.new(0, 140, 1, 0)
toggle.BackgroundColor3 = Color3.fromRGB(70, 70, 75)
toggle.Text = name .. ": Off"
toggle.Font = Enum.Font.Gotham
toggle.TextSize = 12
toggle.TextColor3 = Color3.fromRGB(235,235,235)
local toggleCorner = Instance.new("UICorner", toggle)
toggleCorner.CornerRadius = UDim.new(0, 6)
toggle.Parent = toggleFrame
 
local enabled = Settings[settingKey]
toggle.Text = name .. ": " .. (enabled and "On" or "Off")
toggle.BackgroundColor3 = enabled and Color3.fromRGB(55, 120, 255) or Color3.fromRGB(70, 70, 75)
 
toggle.MouseButton1Click:Connect(function()
enabled = not enabled
Settings[settingKey] = enabled
toggle.Text = name .. ": " .. (enabled and "On" or "Off")
toggle.BackgroundColor3 = enabled and Color3.fromRGB(55, 120, 255) or Color3.fromRGB(70, 70, 75)
if customCallback then
customCallback(enabled)
end
end)
 
return toggle
end

