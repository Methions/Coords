local function setupCharacter(char)
local hum = char:WaitForChild("Humanoid")
hum.WalkSpeed = Settings.SuperSpeed and 100 or 16
hum.JumpPower = Settings.HighJump and 200 or 50

hum.Died:Connect(function()
local hrp = char:FindFirstChild("HumanoidRootPart")
if hrp then
lastDeathPosition = hrp.Position
if Settings.LogTeleports then
print("Saved death position: " .. tostring(lastDeathPosition))
end
end
end)

if Settings.SavePositionOnRespawn and lastDeathPosition then
task.spawn(function()
task.wait(1)
local hrp = char:FindFirstChild("HumanoidRootPart")
if hrp then
hrp.CFrame = CFrame.new(lastDeathPosition) * hrp.CFrame.Rotation
showPopup("Respawned at last death position", Color3.fromRGB(100, 255, 100))
end
end)
end
end

LocalPlayer.CharacterAdded:Connect(setupCharacter)
