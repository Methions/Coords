local function toggleAutoExecute()
    CONFIG.AutoExecuteEnabled = not CONFIG.AutoExecuteEnabled
    updateToggleVisual(CONFIG.AutoExecuteEnabled)

    if CONFIG.AutoExecuteEnabled then
        setupAutoExecute()
    end

    local feedback = Instance.new("TextLabel")
    feedback.Size = UDim2.new(0, 150, 0, 24)
    feedback.Position = UDim2.new(0.5, -75, 0, -30)
    feedback.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
    feedback.Text = CONFIG.AutoExecuteEnabled and "Auto Execute: ON" or "Auto Execute: OFF"
    feedback.TextColor3 = CONFIG.AutoExecuteEnabled and Color3.fromRGB(100, 255, 150) or Color3.fromRGB(255, 100, 100)
    feedback.TextSize = 11
    feedback.Font = Enum.Font.GothamBold
    feedback.Parent = ContextMenu

    local fbCorner = Instance.new("UICorner")
    fbCorner.CornerRadius = UDim.new(0, 4)
    fbCorner.Parent = feedback

    TweenService:Create(feedback, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -75, 0, -28)}):Play()
    task.delay(1.5, function()
        TweenService:Create(feedback, TweenInfo.new(0.3), {BackgroundTransparency = 1, TextTransparency = 1}):Play()
        task.delay(0.3, function() feedback:Destroy() end)
    end)
end

