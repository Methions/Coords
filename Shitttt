local function setupAutoExecute()
    pcall(function()
        if queue_on_teleport then
            queue_on_teleport([[
                -- Auto-execute on teleport
                -- This will re-run the script after server hop
                local loadstringURL = "YOUR_LOADSTRING_URL_HERE"
                if loadstringURL and loadstringURL ~= "YOUR_LOADSTRING_URL_HERE" then
                    pcall(function()
                        loadstring(game:HttpGet(loadstringURL))()
                    end)
                end
            ]])
        end
    end)
end

